# ---- Dependencies ----
node_modules/
.pnp
.pnp.js

# ---- Build Output ----
dist/
dist-ssr/
build/

# ---- Vite Cache ----
.vite/
*.local

# ---- TypeScript ----
*.tsbuildinfo
tsconfig.tsbuildinfo

# ---- Environment Variables ----
# Never commit secrets, API keys, or DB credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging

# ---- Test Coverage ----
coverage/
.nyc_output/

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*
lerna-debug.log*

# ---- OS Generated ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- IDEs & Editors ----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ---- Package Managers ----
# Keep bun.lockb and package-lock.json committed for reproducible installs
# Ignore lock files from OTHER managers to avoid conflicts
yarn.lock
pnpm-lock.yaml

# ---- Misc ----
*.zip
*.tar.gz
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache

# ---- Patient / Medical Data ----
# If you ever handle real patient data locally, never commit it
uploads/
patient-data/
*.dcm
*.hl7
